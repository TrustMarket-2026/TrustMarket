# ============================================================
#  TrustMarket Backend — Variables d'environnement
#  COPIE CE FICHIER en .env et remplis les valeurs
#  NE JAMAIS COMMIT LE FICHIER .env (il est dans .gitignore)
# ============================================================

# --- APPLICATION ---
PORT=3000
NODE_ENV=development
APP_NAME=TrustMarket

# --- BASE DE DONNÉES PostgreSQL ---
# Format : postgresql://UTILISATEUR:MOT_DE_PASSE@HOTE:PORT/NOM_BASE
DATABASE_URL="postgresql://postgres:monmotdepasse@localhost:5432/trustmarket_db"
# Nécessaire pour Prisma Migrate (peut être identique à DATABASE_URL)
SHADOW_DATABASE_URL="postgresql://postgres:monmotdepasse@localhost:5432/trustmarket_shadow"

# --- REDIS (pour BullMQ) ---
REDIS_URL="redis://localhost:6379"

# --- JWT (Tokens d'authentification) ---
JWT_SECRET="CHANGE_MOI_mets_une_longue_chaine_aleatoire_ici"
JWT_REFRESH_SECRET="CHANGE_MOI_autre_longue_chaine_aleatoire_ici"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- RESEND (Envoi d'emails OTP) ---
# Crée un compte sur https://resend.com et génère une clé API
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
FROM_EMAIL="TrustMarket <noreply@trustmarket.bf>"

# --- FIREBASE (Notifications Push FCM) ---
# Récupère ces infos dans la console Firebase > Paramètres du projet > Comptes de service
FIREBASE_PROJECT_ID="trustmarket-app"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXX\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@trustmarket-app.iam.gserviceaccount.com"

# --- CLOUDFLARE R2 (Stockage fichiers / preuves litiges) ---
# Récupère ces infos dans ton dashboard Cloudflare R2
R2_ACCOUNT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
R2_ACCESS_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
R2_SECRET_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
R2_BUCKET="trustmarket-preuves"
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxxxx.r2.dev"

# --- ORANGE MONEY BUSINESS ---
ORANGE_MONEY_API_URL="https://api.orange.com/orange-money-webpay/bf/v1"
ORANGE_MONEY_API_KEY="votre_cle_api_orange_money"
ORANGE_MONEY_WEBHOOK_SECRET="votre_secret_webhook_orange_money"
# Numéro du compte TrustMarket Orange Money (ex: +22607XXXXXXXX)
ORANGE_MONEY_ACCOUNT_PHONE="+22607XXXXXXXX"

# --- WAVE BUSINESS ---
WAVE_API_URL="https://api.wave.com/v1"
WAVE_API_KEY="votre_cle_api_wave"
WAVE_WEBHOOK_SECRET="votre_secret_webhook_wave"
# Numéro du compte TrustMarket Wave (ex: +22601XXXXXXXX)
WAVE_ACCOUNT_PHONE="+22601XXXXXXXX"

# --- COMMISSION & RÈGLES MÉTIER ---
# 0.5% de commission par transaction
COMMISSION_RATE=0.005
# Le QR Code expire après 48h si non scanné
QR_EXPIRY_HOURS=48

# --- CORS ---
# Origines autorisées à appeler l'API (séparées par des virgules)
CORS_ORIGINS="http://localhost:3000,http://localhost:8080"
